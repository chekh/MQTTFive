#!/usr/bin/env bash
set -euo pipefail

WINEPREFIX="${WINEPREFIX:-$HOME/.wine_mt5}"
METAEDITOR="$WINEPREFIX/drive_c/Program Files/MetaTrader 5/MetaEditor64.exe"
PROJECT_ROOT="/Users/chekh/Development/Resadviser/trading-signal/MQTTFive"

if [ $# -eq 0 ]; then
    echo "Usage: mq5-compile <file.mq5> [--syntax]"
    echo "  Compiles MQL5 file via MetaEditor CLI under Wine"
    echo "  --syntax: syntax check only (no .ex5 output)"
    exit 1
fi

FILE="$1"
shift

if [[ "$FILE" != /* ]]; then
    FILE="$(pwd)/$FILE"
fi

WIN_PATH="${FILE/$PROJECT_ROOT/C:\\Program Files\\MetaTrader 5\\MQL5}"
WIN_PATH="${WIN_PATH//\//\\}"

FLAGS="/log"
if [[ "${1:-}" == "--syntax" ]]; then
    FLAGS="/s /log"
fi

echo "Compiling: $WIN_PATH"

WINEPREFIX="$WINEPREFIX" wine "$METAEDITOR" /compile:"$WIN_PATH" $FLAGS 2>/dev/null

LOG_FILE="${FILE%.mq5}.log"
if [ -f "$LOG_FILE" ]; then
    cat "$LOG_FILE"
    rm -f "$LOG_FILE"
else
    echo "WARNING: No log file produced. MetaEditor may need X11 display."
    echo "Fallback: compile from MetaEditor GUI."
fi
